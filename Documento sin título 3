<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YT2TikTok - Recorta, Subtitula y Sube</title>

    <!-- ========== ESTILOS CSS ========== -->
    <style>
        :root {
            --bg: #0f0f0f;
            --bg-card: #1a1a1a;
            --bg-card-hover: #222;
            --text: #e0e0e0;
            --text-secondary: #a0a0a0;
            --accent: #ff0050;
            --accent-glow: #ff3366;
            --accent-yt: #ff0000;
            --accent-tiktok: #ff0050;
            --border: #2a2a2a;
            --border-focus: #444;
            --success: #00f7a7;
            --warning: #ffb347;
            --danger: #ff4444;
            --radius: 12px;
            --radius-sm: 8px;
            --radius-xs: 6px;
            --shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
            --shadow-glow: 0 0 30px rgba(255, 0, 80, 0.25);
            --transition: 0.2s ease;
            --font: 'Inter', 'Segoe UI', system-ui, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font);
            min-height: 100vh;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            background-image:
                radial-gradient(ellipse at 20% 0%, rgba(255, 0, 80, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(255, 0, 0, 0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(100, 100, 255, 0.03) 0%, transparent 60%);
        }

        /* ========== HEADER ========== */
        .header {
            background: rgba(20, 20, 20, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            gap: 16px;
            flex-wrap: wrap;
        }
        .header .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            white-space: nowrap;
        }
        .header .logo .icon-yt {
            color: #ff0000;
            font-size: 1.6rem;
        }
        .header .logo .icon-arrow {
            color: var(--text-secondary);
            margin: 0 2px;
            font-size: 1rem;
        }
        .header .logo .icon-tt {
            color: var(--accent-tiktok);
            font-size: 1.6rem;
        }
        .header .badge {
            background: var(--accent-tiktok);
            color: #fff;
            font-size: 0.7rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            animation: pulse-badge 2s ease-in-out infinite;
        }
        @keyframes pulse-badge {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(255, 0, 80, 0.5);
            }
            50% {
                box-shadow: 0 0 0 12px rgba(255, 0, 80, 0);
            }
        }

        /* ========== CONTENEDOR PRINCIPAL ========== */
        .main-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ========== TARJETAS ========== */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            transition: all var(--transition);
            box-shadow: var(--shadow);
        }
        .card:hover {
            border-color: #333;
        }
        .card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
            font-weight: 700;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-secondary);
        }
        .card-header .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .dot.red {
            background: #ff4444;
            box-shadow: 0 0 8px #ff4444aa;
        }
        .dot.pink {
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent);
        }
        .dot.green {
            background: var(--success);
            box-shadow: 0 0 8px #00f7a7aa;
        }

        /* ========== INPUT URL ========== */
        .url-input-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .url-input-group input {
            flex: 1;
            min-width: 250px;
            padding: 13px 16px;
            background: #111;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            color: #fff;
            font-size: 0.95rem;
            font-family: var(--font);
            transition: all var(--transition);
            outline: none;
        }
        .url-input-group input:focus {
            border-color: var(--accent-yt);
            box-shadow: 0 0 0 3px rgba(255, 0, 0, 0.1);
        }
        .url-input-group input::placeholder {
            color: #555;
        }
        .btn {
            padding: 12px 22px;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font);
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            gap: 7px;
            white-space: nowrap;
        }
        .btn-load {
            background: #ff0000;
            color: #fff;
        }
        .btn-load:hover {
            background: #cc0000;
            box-shadow: 0 4px 20px rgba(255, 0, 0, 0.35);
            transform: translateY(-1px);
        }
        .btn-load:active {
            transform: scale(0.97);
        }
        .btn-accent {
            background: var(--accent);
            color: #fff;
        }
        .btn-accent:hover {
            background: #e00045;
            box-shadow: var(--shadow-glow);
            transform: translateY(-1px);
        }
        .btn-outline {
            background: transparent;
            border: 2px solid var(--border);
            color: #fff;
        }
        .btn-outline:hover {
            border-color: #555;
            background: rgba(255, 255, 255, 0.03);
        }
        .btn-sm {
            padding: 7px 14px;
            font-size: 0.8rem;
            border-radius: var(--radius-xs);
        }
        .btn-xs {
            padding: 5px 10px;
            font-size: 0.7rem;
            border-radius: var(--radius-xs);
        }
        .btn-danger {
            background: #ff4444;
            color: #fff;
        }
        .btn-danger:hover {
            background: #cc0000;
        }
        .btn-success {
            background: #00c853;
            color: #000;
        }
        .btn-success:hover {
            background: #00e676;
            box-shadow: 0 4px 20px rgba(0, 200, 83, 0.4);
        }
        .btn:disabled {
            opacity: 0.4;
            pointer-events: none;
            cursor: not-allowed;
        }

        /* ========== REPRODUCTOR ========== */
        .player-wrapper {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 9;
            background: #000;
            border-radius: var(--radius-sm);
            overflow: hidden;
            max-height: 500px;
        }
        .player-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        .subtitle-overlay {
            position: absolute;
            bottom: 14%;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8);
            color: #fff;
            padding: 8px 18px;
            border-radius: 6px;
            font-size: 1.1rem;
            font-weight: 600;
            text-align: center;
            pointer-events: none;
            z-index: 10;
            max-width: 90%;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
            transition: opacity 0.2s;
            letter-spacing: 0.3px;
        }
        .subtitle-overlay:empty {
            opacity: 0;
            padding: 0;
        }

        /* ========== SECCIÓN RECORTE ========== */
        .trim-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        @media (max-width: 600px) {
            .trim-section {
                grid-template-columns: 1fr;
            }
        }
        .trim-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .trim-group label {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .trim-group input[type="range"] {
            -webkit-appearance: none;
            width: 100%;
            height: 6px;
            border-radius: 3px;
            background: #333;
            outline: none;
            cursor: pointer;
        }
        .trim-group input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--accent);
            cursor: pointer;
            border: 3px solid #fff;
            box-shadow: 0 0 12px rgba(255, 0, 80, 0.5);
            transition: all var(--transition);
        }
        .trim-group input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.15);
            box-shadow: 0 0 20px rgba(255, 0, 80, 0.7);
        }
        .time-display {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 1px;
        }
        .time-display .time-val {
            background: #111;
            padding: 6px 12px;
            border-radius: var(--radius-xs);
            border: 1px solid var(--border);
        }
        .duration-badge {
            background: var(--accent);
            color: #fff;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* ========== TABLA SUBTÍTULOS ========== */
        .subtitle-table-wrap {
            overflow-x: auto;
            max-height: 300px;
            overflow-y: auto;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
        }
        .subtitle-table-wrap::-webkit-scrollbar {
            width: 5px;
        }
        .subtitle-table-wrap::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 3px;
        }
        table.subtitle-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        table.subtitle-table thead {
            background: #111;
            position: sticky;
            top: 0;
            z-index: 2;
        }
        table.subtitle-table th {
            padding: 10px 8px;
            text-align: left;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-secondary);
            border-bottom: 2px solid var(--border);
        }
        table.subtitle-table td {
            padding: 8px;
            border-bottom: 1px solid #1f1f1f;
            vertical-align: middle;
        }
        table.subtitle-table tbody tr {
            transition: background var(--transition);
        }
        table.subtitle-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        table.subtitle-table tbody tr.active-sub {
            background: rgba(255, 0, 80, 0.12) !important;
            border-left: 3px solid var(--accent);
        }
        table.subtitle-table input[type="text"],
        table.subtitle-table input[type="number"] {
            background: #111;
            border: 1px solid #2a2a2a;
            color: #fff;
            padding: 6px 8px;
            border-radius: var(--radius-xs);
            width: 100%;
            font-family: var(--font);
            font-size: 0.82rem;
            transition: all var(--transition);
        }
        table.subtitle-table input:focus {
            border-color: var(--accent);
            outline: none;
            box-shadow: 0 0 0 2px rgba(255, 0, 80, 0.1);
        }
        .text-col {
            min-width: 180px;
        }
        .time-col {
            min-width: 75px;
            text-align: center;
        }
        .action-col {
            width: 40px;
            text-align: center;
        }
        .no-subs {
            text-align: center;
            padding: 30px;
            color: #555;
            font-style: italic;
        }

        /* ========== BOTONES DE ACCIÓN RÁPIDA ========== */
        .quick-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        /* ========== MODAL ========== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
            animation: fadeIn 0.25s ease;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
        .modal {
            background: #1a1a1a;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 28px 24px;
            width: 90%;
            max-width: 480px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);
            animation: slideUp 0.3s ease;
        }
        @keyframes slideUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        .modal h3 {
            font-size: 1.2rem;
            margin-bottom: 16px;
            letter-spacing: -0.3px;
        }
        .progress-bar-wrap {
            background: #222;
            border-radius: 10px;
            height: 12px;
            overflow: hidden;
            margin: 16px 0;
        }
        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff0050, #ff3366);
            border-radius: 10px;
            transition: width 0.4s ease;
            box-shadow: 0 0 15px rgba(255, 0, 80, 0.5);
        }
        .progress-step {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin: 6px 0;
        }
        .checkmark {
            font-size: 4rem;
            color: var(--success);
            animation: popIn 0.4s ease;
        }
        @keyframes popIn {
            from {
                transform: scale(0);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        /* ========== TOAST ========== */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 300;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .toast {
            background: #222;
            border: 1px solid #444;
            color: #fff;
            padding: 12px 18px;
            border-radius: var(--radius-sm);
            font-size: 0.85rem;
            font-weight: 500;
            animation: slideInRight 0.3s ease, fadeOut 0.3s ease 2.5s forwards;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
            max-width: 350px;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(120%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        @keyframes fadeOut {
            to {
                opacity: 0;
                transform: translateY(-10px);
            }
        }
        .toast.success {
            border-left: 3px solid var(--success);
        }
        .toast.error {
            border-left: 3px solid var(--danger);
        }
        .toast.info {
            border-left: 3px solid #448aff;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 768px) {
            .header {
                padding: 10px 14px;
            }
            .header .logo {
                font-size: 1.1rem;
            }
            .main-container {
                padding: 12px;
                gap: 14px;
            }
            .card {
                padding: 14px;
            }
            .player-wrapper {
                aspect-ratio: 4/3;
                max-height: 300px;
            }
            .subtitle-overlay {
                font-size: 0.9rem;
                bottom: 10%;
                padding: 6px 12px;
            }
            .time-display {
                font-size: 1rem;
            }
            table.subtitle-table {
                font-size: 0.75rem;
            }
        }
    </style>

    <!-- Fuente Inter desde Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <!-- ========== HEADER ========== -->
    <header class="header">
        <div class="logo">
            <span class="icon-yt">▶</span> YouTube
            <span class="icon-arrow">→</span>
            <span class="icon-tt">♪</span> TikTok
        </div>
        <span class="badge">🎬 Clip Maker</span>
    </header>

    <!-- ========== CONTENEDOR PRINCIPAL ========== -->
    <div class="main-container">

        <!-- Tarjeta 1: Cargar Video -->
        <div class="card" id="card-load">
            <div class="card-header">
                <span class="dot red"></span> Cargar Video de YouTube
            </div>
            <div class="url-input-group">
                <input
                type="text"
                id="youtube-url"
                placeholder="Pega aquí la URL del video de YouTube..."
                autocomplete="off"
                >
                <button class="btn btn-load" id="btn-load" title="Cargar video">
                    📥 Cargar Video
                </button>
            </div>
            <div style="font-size:0.7rem;color:#555;margin-top:6px;">
                Ejemplos: youtube.com/watch?v=... | youtu.be/... | youtube.com/shorts/...
            </div>
        </div>

        <!-- Tarjeta 2: Reproductor + Subtítulos en vivo -->
        <div class="card" id="card-player" style="display:none;">
            <div class="card-header">
                <span class="dot pink"></span> Reproductor & Vista Previa
                <span style="font-size:0.7rem;color:#888;margin-left:auto;" id="current-time-live">00:00</span>
            </div>
            <div class="player-wrapper" id="player-wrapper">
                <div id="youtube-player"></div>
                <div class="subtitle-overlay" id="subtitle-overlay"></div>
            </div>
        </div>

        <!-- Tarjeta 3: Recorte -->
        <div class="card" id="card-trim" style="display:none;">
            <div class="card-header">
                <span class="dot pink"></span> Recortar Clip
                <span class="duration-badge" id="clip-duration-badge">Duración: 00:00</span>
            </div>
            <div class="trim-section">
                <div class="trim-group">
                    <label>🎬 Inicio del clip</label>
                    <input type="range" id="trim-start-range" min="0" max="100" value="0" step="0.1">
                    <div class="time-display">
                        <span class="time-val" id="trim-start-display">00:00</span>
                        <button class="btn btn-outline btn-xs" id="btn-mark-start" title="Usar tiempo actual">📍 Marcar actual</button>
                    </div>
                </div>
                <div class="trim-group">
                    <label>🏁 Fin del clip</label>
                    <input type="range" id="trim-end-range" min="0" max="100" value="100" step="0.1">
                    <div class="time-display">
                        <span class="time-val" id="trim-end-display">00:00</span>
                        <button class="btn btn-outline btn-xs" id="btn-mark-end" title="Usar tiempo actual">📍 Marcar actual</button>
                    </div>
                </div>
            </div>
            <div class="quick-actions">
                <button class="btn btn-outline btn-sm" id="btn-play-trim">▶ Reproducir clip</button>
                <button class="btn btn-outline btn-sm" id="btn-reset-trim">↺ Resetear recorte</button>
                <span style="font-size:0.7rem;color:#888;margin-left:auto;align-self:center;">
                    Atajos: <kbd style="background:#222;padding:2px 6px;border-radius:3px;">I</kbd> inicio |
                    <kbd style="background:#222;padding:2px 6px;border-radius:3px;">O</kbd> fin
                </span>
            </div>
        </div>

        <!-- Tarjeta 4: Subtítulos -->
        <div class="card" id="card-subs" style="display:none;">
            <div class="card-header">
                <span class="dot green"></span> Editor de Subtítulos
                <span style="font-size:0.7rem;color:#888;margin-left:auto;" id="sub-count">0 subtítulos</span>
            </div>
            <div class="subtitle-table-wrap">
                <table class="subtitle-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th class="text-col">Texto del subtítulo</th>
                            <th class="time-col">Inicio (s)</th>
                            <th class="time-col">Fin (s)</th>
                            <th class="action-col"></th>
                        </tr>
                    </thead>
                    <tbody id="subtitle-tbody">
                        <tr class="no-subs">
                            <td colspan="5">No hay subtítulos. Añade uno con el botón de abajo o presiona <kbd style="background:#222;padding:2px 6px;border-radius:3px;">S</kbd></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="quick-actions">
                <button class="btn btn-accent btn-sm" id="btn-add-sub">➕ Añadir subtítulo</button>
                <button class="btn btn-outline btn-sm" id="btn-add-sub-current">📍 Desde tiempo actual</button>
                <button class="btn btn-outline btn-sm" id="btn-clear-subs">🗑️ Limpiar todos</button>
                <span style="font-size:0.7rem;color:#888;margin-left:auto;align-self:center;">
                    Atajo: <kbd style="background:#222;padding:2px 6px;border-radius:3px;">S</kbd> añadir
                </span>
            </div>
        </div>

        <!-- Tarjeta 5: Acción Final -->
        <div class="card" id="card-upload" style="display:none;">
            <div class="card-header">
                <span class="dot green"></span> Exportar a TikTok
            </div>
            <p style="color:var(--text-secondary);font-size:0.85rem;margin-bottom:12px;">
                Clip listo: <strong id="summary-duration">00:00</strong> |
                <strong id="summary-subs">0</strong> subtítulos |
                Formato optimizado 9:16 vertical
            </p>
            <button class="btn btn-success btn-lg" id="btn-upload-tiktok" style="width:100%;justify-content:center;font-size:1rem;padding:16px;">
                🚀 Subir a TikTok
            </button>
            <p style="font-size:0.65rem;color:#555;margin-top:8px;text-align:center;">
                * Simulación: se procesará el video con los ajustes configurados
            </p>
        </div>
    </div>

    <!-- ========== TOAST CONTAINER ========== -->
    <div class="toast-container" id="toast-container"></div>

    <!-- ========== MODAL DE PROGRESO ========== -->
    <div class="modal-overlay" id="modal-overlay" style="display:none;">
        <div class="modal" id="modal-content">
            <!-- Se llena dinámicamente -->
        </div>
    </div>

    <!-- ========== YOUTUBE IFrame API ========== -->
    <script>
        // ==================== VARIABLES GLOBALES ====================
        let player = null;
        let playerReady = false;
        let videoDuration = 0;
        let videoId = null;
        let trimStart = 0; // segundos
        let trimEnd = 0; // segundos
        let subtitles = []; // {id, text, startTime, endTime}
        let subtitleIdCounter = 0;
        let currentActiveSubId = null;
        let updateInterval = null;

        // ==================== ELEMENTOS DOM ====================
        const $youtubeUrl = document.getElementById('youtube-url');
        const $btnLoad = document.getElementById('btn-load');
        const $cardPlayer = document.getElementById('card-player');
        const $cardTrim = document.getElementById('card-trim');
        const $cardSubs = document.getElementById('card-subs');
        const $cardUpload = document.getElementById('card-upload');
        const $playerWrapper = document.getElementById('player-wrapper');
        const $subtitleOverlay = document.getElementById('subtitle-overlay');
        const $currentTimeLive = document.getElementById('current-time-live');
        const $trimStartRange = document.getElementById('trim-start-range');
        const $trimEndRange = document.getElementById('trim-end-range');
        const $trimStartDisplay = document.getElementById('trim-start-display');
        const $trimEndDisplay = document.getElementById('trim-end-display');
        const $clipDurationBadge = document.getElementById('clip-duration-badge');
        const $subtitleTbody = document.getElementById('subtitle-tbody');
        const $subCount = document.getElementById('sub-count');
        const $summaryDuration = document.getElementById('summary-duration');
        const $summarySubs = document.getElementById('summary-subs');
        const $btnMarkStart = document.getElementById('btn-mark-start');
        const $btnMarkEnd = document.getElementById('btn-mark-end');
        const $btnPlayTrim = document.getElementById('btn-play-trim');
        const $btnResetTrim = document.getElementById('btn-reset-trim');
        const $btnAddSub = document.getElementById('btn-add-sub');
        const $btnAddSubCurrent = document.getElementById('btn-add-sub-current');
        const $btnClearSubs = document.getElementById('btn-clear-subs');
        const $btnUploadTiktok = document.getElementById('btn-upload-tiktok');
        const $modalOverlay = document.getElementById('modal-overlay');
        const $modalContent = document.getElementById('modal-content');
        const $toastContainer = document.getElementById('toast-container');

        // ==================== UTILIDADES ====================
        function formatTime(seconds) {
            if (isNaN(seconds) || seconds < 0) return '00:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
        }

        function formatTimeMs(seconds) {
            if (isNaN(seconds) || seconds < 0) return '00:00.0';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            const ms = Math.floor((seconds % 1) * 10);
            return String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0') + '.' + ms;
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = message;
            $toastContainer.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) toast.parentNode.removeChild(toast);
            }, 3000);
        }

        function extractYouTubeID(url) {
            if (!url || typeof url !== 'string') return null;
            url = url.trim();
            // youtu.be/ID
            const shortMatch = url.match(/(?:https?:\/\/)?youtu\.be\/([a-zA-Z0-9_-]{11})/);
            if (shortMatch) return shortMatch[1];
            // youtube.com/shorts/ID
            const shortsMatch = url.match(/(?:https?:\/\/)?(?:www\.)?youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/);
            if (shortsMatch) return shortsMatch[1];
            // youtube.com/watch?v=ID
            const watchMatch = url.match(/(?:https?:\/\/)?(?:www\.)?youtube\.com\/watch\?.*v=([a-zA-Z0-9_-]{11})/);
            if (watchMatch) return watchMatch[1];
            // youtube.com/embed/ID
            const embedMatch = url.match(/(?:https?:\/\/)?(?:www\.)?youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/);
            if (embedMatch) return embedMatch[1];
            // Si son solo 11 caracteres válidos
            const directMatch = url.match(/^([a-zA-Z0-9_-]{11})$/);
            if (directMatch) return directMatch[1];
            return null;
        }

        // ==================== YOUTUBE API ====================
        function onYouTubeIframeAPIReady() {
            // La API está lista, pero creamos el player cuando se cargue un video
        }

        function createPlayer(videoIdParam) {
            // Limpiar player anterior
            if (player) {
                try { player.destroy(); } catch (e) {}
                player = null;
            }
            playerReady = false;
            document.getElementById('youtube-player').innerHTML = '';

            player = new YT.Player('youtube-player', {
                videoId: videoIdParam,
                playerVars: {
                    autoplay: 0,
                    controls: 1,
                    modestbranding: 1,
                    rel: 0,
                    fs: 1,
                    iv_load_policy: 3,
                    cc_load_policy: 0,
                },
                events: {
                    onReady: onPlayerReady,
                    onStateChange: onPlayerStateChange,
                    onError: onPlayerError,
                },
            });
        }

        function onPlayerReady(event) {
            playerReady = true;
            videoDuration = player.getDuration();
            trimStart = 0;
            trimEnd = videoDuration;
            updateTrimRanges();
            updateTrimDisplays();
            updateClipDurationBadge();
            $cardPlayer.style.display = '';
            $cardTrim.style.display = '';
            $cardSubs.style.display = '';
            $cardUpload.style.display = '';
            startUpdateLoop();
            showToast('✅ Video cargado correctamente', 'success');
            // Scroll al reproductor
            $cardPlayer.scrollIntoView({ behavior: 'smooth', block: 'center' });
            updateSummary();
        }

        function onPlayerStateChange(event) {
            if (event.data === YT.PlayerState.PLAYING) {
                startUpdateLoop();
            }
            if (event.data === YT.PlayerState.ENDED) {
                // Si estamos en modo "recorte", podríamos hacer loop
                if (trimEnd < videoDuration - 0.1 && trimStart > 0.01) {
                    // El clip terminó, volver al inicio del recorte
                    setTimeout(() => {
                        if (player && playerReady) {
                            player.seekTo(trimStart, true);
                            player.playVideo();
                        }
                    }, 300);
                }
            }
        }

        function onPlayerError(event) {
            showToast('❌ Error al cargar el video. Verifica la URL.', 'error');
            console.error('YT Player error:', event);
        }

        function startUpdateLoop() {
            if (updateInterval) clearInterval(updateInterval);
            updateInterval = setInterval(updateLiveData, 150);
        }

        function stopUpdateLoop() {
            if (updateInterval) {
                clearInterval(updateInterval);
                updateInterval = null;
            }
        }

        function updateLiveData() {
            if (!playerReady || !player) return;
            try {
                const currentTime = player.getCurrentTime();
                $currentTimeLive.textContent = formatTimeMs(currentTime);

                // Actualizar subtítulo activo
                let activeSub = null;
                for (const sub of subtitles) {
                    if (currentTime >= sub.startTime && currentTime <= sub.endTime) {
                        activeSub = sub;
                        break;
                    }
                }
                if (activeSub && activeSub.id !== currentActiveSubId) {
                    currentActiveSubId = activeSub.id;
                    $subtitleOverlay.textContent = activeSub.text;
                    highlightSubtitleRow(activeSub.id);
                } else if (!activeSub && currentActiveSubId !== null) {
                    currentActiveSubId = null;
                    $subtitleOverlay.textContent = '';
                    highlightSubtitleRow(null);
                }
                // Actualizar texto si cambió pero mismo ID
                if (activeSub && activeSub.id === currentActiveSubId) {
                    if ($subtitleOverlay.textContent !== activeSub.text) {
                        $subtitleOverlay.textContent = activeSub.text;
                    }
                }

                // Si el video pasó del trimEnd, hacer loop al trimStart
                if (trimEnd < videoDuration && currentTime >= trimEnd) {
                    player.seekTo(trimStart, true);
                    player.playVideo();
                }
            } catch (e) {
                // Silencioso
            }
        }

        function highlightSubtitleRow(subId) {
            const rows = $subtitleTbody.querySelectorAll('tr');
            rows.forEach(row => {
                if (subId !== null && row.dataset.subId === String(subId)) {
                    row.classList.add('active-sub');
                } else {
                    row.classList.remove('active-sub');
                }
            });
        }

        // ==================== RECORTE ====================
        function updateTrimRanges() {
            $trimStartRange.max = videoDuration;
            $trimEndRange.max = videoDuration;
            $trimStartRange.value = trimStart;
            $trimEndRange.value = trimEnd;
        }

        function updateTrimDisplays() {
            $trimStartDisplay.textContent = formatTimeMs(trimStart);
            $trimEndDisplay.textContent = formatTimeMs(trimEnd);
        }

        function updateClipDurationBadge() {
            const duration = Math.max(0, trimEnd - trimStart);
            $clipDurationBadge.textContent = 'Duración: ' + formatTime(duration);
        }

        function setTrimStart(value) {
            trimStart = Math.max(0, Math.min(value, trimEnd - 1));
            if (trimStart >= trimEnd) trimStart = Math.max(0, trimEnd - 1);
            $trimStartRange.value = trimStart;
            updateTrimDisplays();
            updateClipDurationBadge();
            updateSummary();
        }

        function setTrimEnd(value) {
            trimEnd = Math.min(videoDuration, Math.max(value, trimStart + 1));
            if (trimEnd <= trimStart) trimEnd = Math.min(videoDuration, trimStart + 1);
            $trimEndRange.value = trimEnd;
            updateTrimDisplays();
            updateClipDurationBadge();
            updateSummary();
        }

        $trimStartRange.addEventListener('input', () => {
            setTrimStart(parseFloat($trimStartRange.value));
        });
        $trimEndRange.addEventListener('input', () => {
            setTrimEnd(parseFloat($trimEndRange.value));
        });

        $btnMarkStart.addEventListener('click', () => {
            if (!playerReady) return;
            const ct = player.getCurrentTime();
            setTrimStart(ct);
            showToast('📍 Inicio marcado en ' + formatTimeMs(ct), 'info');
        });
        $btnMarkEnd.addEventListener('click', () => {
            if (!playerReady) return;
            const ct = player.getCurrentTime();
            setTrimEnd(ct);
            showToast('📍 Fin marcado en ' + formatTimeMs(ct), 'info');
        });
        $btnPlayTrim.addEventListener('click', () => {
            if (!playerReady) return;
            player.seekTo(trimStart, true);
            player.playVideo();
            showToast('▶ Reproduciendo clip desde ' + formatTimeMs(trimStart), 'info');
        });
        $btnResetTrim.addEventListener('click', () => {
            trimStart = 0;
            trimEnd = videoDuration;
            updateTrimRanges();
            updateTrimDisplays();
            updateClipDurationBadge();
            updateSummary();
            showToast('↺ Recorte reseteado', 'info');
        });

        // ==================== SUBTÍTULOS ====================
        function renderSubtitles() {
            $subtitleTbody.innerHTML = '';
            if (subtitles.length === 0) {
                $subtitleTbody.innerHTML =
                    '<tr class="no-subs"><td colspan="5">No hay subtítulos. Añade uno con el botón de abajo o presiona <kbd style="background:#222;padding:2px 6px;border-radius:3px;">S</kbd></td></tr>';
            } else {
                subtitles.forEach((sub, index) => {
                    const tr = document.createElement('tr');
                    tr.dataset.subId = sub.id;
                    if (sub.id === currentActiveSubId) tr.classList.add('active-sub');
                    tr.innerHTML = `
                        <td style="color:#888;text-align:center;">${index + 1}</td>
                        <td class="text-col">
                            <input type="text" value="${escapeHtml(sub.text)}" 
                                   data-sub-id="${sub.id}" class="sub-text-input" 
                                   placeholder="Escribe el subtítulo...">
                        </td>
                        <td class="time-col">
                            <input type="number" value="${sub.startTime.toFixed(1)}" 
                                   data-sub-id="${sub.id}" class="sub-start-input" 
                                   step="0.1" min="0" style="width:65px;text-align:center;">
                        </td>
                        <td class="time-col">
                            <input type="number" value="${sub.endTime.toFixed(1)}" 
                                   data-sub-id="${sub.id}" class="sub-end-input" 
                                   step="0.1" min="0" style="width:65px;text-align:center;">
                        </td>
                        <td class="action-col">
                            <button class="btn btn-danger btn-xs delete-sub-btn" data-sub-id="${sub.id}" title="Eliminar">✕</button>
                        </td>
                    `;
                    $subtitleTbody.appendChild(tr);
                });
                // Event listeners
                $subtitleTbody.querySelectorAll('.sub-text-input').forEach(input => {
                    input.addEventListener('input', (e) => {
                        const subId = parseInt(e.target.dataset.subId);
                        const sub = subtitles.find(s => s.id === subId);
                        if (sub) sub.text = e.target.value;
                        updateSummary();
                    });
                });
                $subtitleTbody.querySelectorAll('.sub-start-input').forEach(input => {
                    input.addEventListener('input', (e) => {
                        const subId = parseInt(e.target.dataset.subId);
                        const sub = subtitles.find(s => s.id === subId);
                        if (sub) sub.startTime = parseFloat(e.target.value) || 0;
                        updateSummary();
                    });
                });
                $subtitleTbody.querySelectorAll('.sub-end-input').forEach(input => {
                    input.addEventListener('input', (e) => {
                        const subId = parseInt(e.target.dataset.subId);
                        const sub = subtitles.find(s => s.id === subId);
                        if (sub) sub.endTime = parseFloat(e.target.value) || 0;
                        updateSummary();
                    });
                });
                $subtitleTbody.querySelectorAll('.delete-sub-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const subId = parseInt(e.target.dataset.subId);
                        deleteSubtitle(subId);
                    });
                });
            }
            $subCount.textContent = subtitles.length + ' subtítulo' + (subtitles.length !== 1 ? 's' :
                '');
            updateSummary();
        }

        function escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        function addSubtitle(text = '', startTime = null, endTime = null) {
            if (startTime === null && playerReady) startTime = player.getCurrentTime();
            if (startTime === null) startTime = trimStart;
            if (endTime === null) endTime = startTime + 3;
            if (endTime <= startTime) endTime = startTime + 3;
            if (endTime > videoDuration) endTime = videoDuration;

            const newSub = {
                id: ++subtitleIdCounter,
                text: text || 'Nuevo subtítulo',
                startTime: Math.round(startTime * 10) / 10,
                endTime: Math.round(endTime * 10) / 10,
            };
            subtitles.push(newSub);
            // Ordenar por startTime
            subtitles.sort((a, b) => a.startTime - b.startTime);
            renderSubtitles();
            showToast('➕ Subtítulo añadido', 'success');
            return newSub;
        }

        function deleteSubtitle(subId) {
            subtitles = subtitles.filter(s => s.id !== subId);
            if (currentActiveSubId === subId) {
                currentActiveSubId = null;
                $subtitleOverlay.textContent = '';
            }
            renderSubtitles();
            showToast('🗑️ Subtítulo eliminado', 'info');
        }

        $btnAddSub.addEventListener('click', () => {
            const startT = playerReady ? player.getCurrentTime() : trimStart;
            addSubtitle('', startT, startT + 3);
        });
        $btnAddSubCurrent.addEventListener('click', () => {
            if (!playerReady) {
                showToast('⚠️ Carga un video primero', 'error');
                return;
            }
            const ct = player.getCurrentTime();
            addSubtitle('', ct, ct + 3);
            showToast('📍 Subtítulo desde ' + formatTimeMs(ct), 'info');
        });
        $btnClearSubs.addEventListener('click', () => {
            if (subtitles.length === 0) return;
            if (confirm('¿Eliminar todos los subtítulos?')) {
                subtitles = [];
                currentActiveSubId = null;
                $subtitleOverlay.textContent = '';
                renderSubtitles();
                showToast('🗑️ Todos los subtítulos eliminados', 'info');
            }
        });

        // ==================== CARGA DE VIDEO ====================
        $btnLoad.addEventListener('click', () => {
            const url = $youtubeUrl.value.trim();
            if (!url) {
                showToast('⚠️ Pega una URL de YouTube', 'error');
                return;
            }
            const extractedId = extractYouTubeID(url);
            if (!extractedId) {
                showToast('❌ URL de YouTube no válida', 'error');
                return;
            }
            videoId = extractedId;
            subtitles = [];
            currentActiveSubId = null;
            $subtitleOverlay.textContent = '';
            trimStart = 0;
            trimEnd = 0;
            videoDuration = 0;
            renderSubtitles();
            stopUpdateLoop();

            if (player) {
                try { player.destroy(); } catch (e) {}
                player = null;
            }
            playerReady = false;
            document.getElementById('youtube-player').innerHTML = '';

            $cardPlayer.style.display = '';
            $cardTrim.style.display = 'none';
            $cardSubs.style.display = 'none';
            $cardUpload.style.display = 'none';

            createPlayer(videoId);
            showToast('🔄 Cargando video...', 'info');
        });

        // También cargar al presionar Enter en el input
        $youtubeUrl.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                $btnLoad.click();
            }
        });

        // ==================== ATAJOS DE TECLADO ====================
        document.addEventListener('keydown', (e) => {
            // Ignorar si el foco está en un input/texto (excepto shortcuts globales)
            const tag = document.activeElement?.tagName?.toLowerCase();
            const isInput = tag === 'input' || tag === 'textarea' || tag === 'select';
            const isContentEditable = document.activeElement?.isContentEditable;

            if (isInput || isContentEditable) {
                // En inputs, solo permitimos ciertos atajos
                if (e.key === 'Escape') {
                    document.activeElement.blur();
                }
                return;
            }

            if (!playerReady) return;

            switch (e.key.toLowerCase()) {
                case ' ':
                    e.preventDefault();
                    if (player.getPlayerState() === YT.PlayerState.PLAYING) {
                        player.pauseVideo();
                    } else {
                        player.playVideo();
                    }
                    break;
                case 'i':
                    e.preventDefault();
                    setTrimStart(player.getCurrentTime());
                    showToast('📍 Inicio: ' + formatTimeMs(trimStart), 'info');
                    break;
                case 'o':
                    e.preventDefault();
                    setTrimEnd(player.getCurrentTime());
                    showToast('📍 Fin: ' + formatTimeMs(trimEnd), 'info');
                    break;
                case 's':
                    e.preventDefault();
                    const ct = player.getCurrentTime();
                    addSubtitle('', ct, ct + 3);
                    break;
                case 'arrowleft':
                    e.preventDefault();
                    player.seekTo(Math.max(0, player.getCurrentTime() - 5), true);
                    break;
                case 'arrowright':
                    e.preventDefault();
                    player.seekTo(Math.min(videoDuration, player.getCurrentTime() + 5), true);
                    break;
                case 'arrowup':
                    e.preventDefault();
                    player.setVolume(Math.min(100, player.getVolume() + 10));
                    break;
                case 'arrowdown':
                    e.preventDefault();
                    player.setVolume(Math.max(0, player.getVolume() - 10));
                    break;
            }
        });

        // ==================== RESUMEN / EXPORTACIÓN ====================
        function updateSummary() {
            const duration = Math.max(0, trimEnd - trimStart);
            $summaryDuration.textContent = formatTime(duration);
            $summarySubs.textContent = subtitles.length;
            if (videoDuration > 0 && $cardUpload.style.display === 'none') {
                $cardUpload.style.display = '';
            }
        }

        // ==================== SIMULACIÓN DE SUBIDA A TIKTOK ====================
        $btnUploadTiktok.addEventListener('click', () => {
            const clipDuration = Math.max(0, trimEnd - trimStart);
            if (clipDuration < 1) {
                showToast('⚠️ El clip debe durar al menos 1 segundo', 'error');
                return;
            }
            if (clipDuration > 600) {
                showToast('⚠️ TikTok permite máximo 10 minutos. El clip es muy largo.', 'error');
                return;
            }

            // Mostrar modal de progreso
            $modalOverlay.style.display = '';
            $modalContent.innerHTML = `
                <h3>🚀 Procesando para TikTok...</h3>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill" id="progress-fill" style="width:0%;"></div>
                </div>
                <p class="progress-step" id="progress-step">Iniciando...</p>
            `;

            const steps = [
                { message: '📥 Descargando video de YouTube...', progress: 15, delay: 1200 },
                { message: '✂️ Recortando clip (' + formatTime(clipDuration) + ')...', progress: 30,
                    delay: 1000 },
                { message: '📝 Aplicando ' + subtitles.length + ' subtítulos...', progress: 55, delay: 1500 },
                { message: '📱 Optimizando formato 9:16 para TikTok...', progress: 75, delay: 1200 },
                { message: '☁️ Subiendo a TikTok...', progress: 90, delay: 1800 },
                { message: '✅ ¡Publicado en TikTok!', progress: 100, delay: 600 },
            ];

            let stepIndex = 0;

            function processStep() {
                if (stepIndex >= steps.length) {
                    // Completado
                    setTimeout(() => {
                        $modalContent.innerHTML = `
                            <div class="checkmark">✅</div>
                            <h3>¡Video subido a TikTok!</h3>
                            <p style="color:var(--text-secondary);margin:8px 0;">
                                Clip de <strong>${formatTime(clipDuration)}</strong> con <strong>${subtitles.length}</strong> subtítulos
                            </p>
                            <p style="font-size:0.7rem;color:#555;">
                                TikTok @usuario • ${new Date().toLocaleDateString()}
                            </p>
                            <button class="btn btn-accent" id="btn-close-modal" style="margin-top:16px;">
                                Cerrar
                            </button>
                        `;
                        document.getElementById('btn-close-modal').addEventListener('click', () => {
                            $modalOverlay.style.display = 'none';
                            showToast('🎉 ¡Simulación completada! El video estaría listo en TikTok.',
                                'success');
                        });
                    }, 400);
                    return;
                }

                const step = steps[stepIndex];
                document.getElementById('progress-fill').style.width = step.progress + '%';
                document.getElementById('progress-step').textContent = step.message;

                stepIndex++;
                setTimeout(processStep, step.delay);
            }

            setTimeout(processStep, 300);
        });

        // Cerrar modal al hacer clic fuera
        $modalOverlay.addEventListener('click', (e) => {
            if (e.target === $modalOverlay) {
                // Solo cerrar si ya terminó (tiene checkmark o btn-close-modal)
                const hasCheckmark = $modalContent.querySelector('.checkmark');
                const hasCloseBtn = $modalContent.querySelector('#btn-close-modal');
                if (hasCheckmark || hasCloseBtn) {
                    $modalOverlay.style.display = 'none';
                }
            }
        });

        // ==================== INICIALIZACIÓN ====================
        function init() {
            // La YouTube API se cargará desde el script externo
            // Si la API ya está disponible, el callback onYouTubeIframeAPIReady se llamará automáticamente
            $cardPlayer.style.display = 'none';
            $cardTrim.style.display = 'none';
            $cardSubs.style.display = 'none';
            $cardUpload.style.display = 'none';
            renderSubtitles();
            console.log('🎬 YT2TikTok inicializado. Pega una URL de YouTube para comenzar.');
            console.log('   Atajos: Espacio=Play/Pause | I=Inicio recorte | O=Fin recorte | S=Añadir subtítulo');
            console.log('   Flechas: ←→ = -5/+5s | ↑↓ = Volumen');
        }

        // Cargar la API de YouTube dinámicamente
        function loadYouTubeAPI() {
            if (window.YT && window.YT.Player) {
                // Ya está cargada
                return;
            }
            const tag = document.createElement('script');
            tag.src = 'https://www.youtube.com/iframe_api';
            const firstScriptTag = document.getElementsByTagName('script')[0];
            firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
        }

        // Asegurarse de que onYouTubeIframeAPIReady sea global
        window.onYouTubeIframeAPIReady = function() {
            console.log('✅ YouTube IFrame API lista');
            // Si ya hay un videoId pendiente, crear player
            if (videoId && !player) {
                createPlayer(videoId);
            }
        };

        // Iniciar
        loadYouTubeAPI();
        init();

        // ==================== LIMPIEZA AL SALIR ====================
        window.addEventListener('beforeunload', () => {
            stopUpdateLoop();
            if (player) {
                try { player.destroy(); } catch (e) {}
